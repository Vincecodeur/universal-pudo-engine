###############################################################################
# Universal PUDO Engine
# Example Environment Configuration
###############################################################################

###############################################################################
# Application
###############################################################################

APP_NAME=Universal PUDO Engine
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO

###############################################################################
# API
###############################################################################

API_HOST=0.0.0.0
API_PORT=8000

###############################################################################
# PostgreSQL
###############################################################################

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=universal_pudo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/universal_pudo

###############################################################################
# Alembic
###############################################################################

ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres:change_me@localhost:5432/universal_pudo

###############################################################################
# General HTTP Settings
###############################################################################

HTTP_TIMEOUT_SECONDS=30
HTTP_RETRY_COUNT=3

###############################################################################
# Carrier Providers
# Only populate the providers you actually use.
###############################################################################

# ---------------------------------------------------------------------------
# Colissimo
# ---------------------------------------------------------------------------

COLISSIMO_ENABLED=false
COLISSIMO_API_KEY=
COLISSIMO_API_SECRET=

# ---------------------------------------------------------------------------
# Mondial Relay
# ---------------------------------------------------------------------------

MONDIAL_RELAY_ENABLED=false
MONDIAL_RELAY_API_KEY=
MONDIAL_RELAY_API_SECRET=

# ---------------------------------------------------------------------------
# Chronopost
# ---------------------------------------------------------------------------

CHRONOPOST_ENABLED=false
CHRONOPOST_API_KEY=
CHRONOPOST_API_SECRET=

# ---------------------------------------------------------------------------
# GLS
# ---------------------------------------------------------------------------

GLS_ENABLED=false
GLS_API_KEY=
GLS_API_SECRET=

# ---------------------------------------------------------------------------
# UPS
# ---------------------------------------------------------------------------

UPS_ENABLED=false
UPS_API_KEY=
UPS_API_SECRET=

# ---------------------------------------------------------------------------
# DPD France
# ---------------------------------------------------------------------------

DPD_FR_ENABLED=false
DPD_FR_API_KEY=
DPD_FR_API_SECRET=

###############################################################################
# Future Features
###############################################################################

CACHE_ENABLED=false

###############################################################################
# Security
###############################################################################

SECRET_KEY=replace_with_real_secret